<% content_for :title, "Loyalty Lookup" %>

<div class="d-flex align-items-center justify-content-center py-5">
  <div class="card lookup-card">
    <div class="card-body p-5">
      <div class="text-center mb-4">
        <div class="brand-lockup justify-content-center mb-4">
          <span class="brand-mark" aria-hidden="true"><%= image_tag "/icon.svg?v=#{pwa_cache_buster}", alt: "", class: "brand-mark-image" %></span>
          <span class="logo-text">Fuel Loyalty</span>
        </div>
        <h1 class="h4 mb-2">Loyalty Lookup</h1>
        <p class="small-muted mb-0">Enter your mobile number to view your current loyalty points and recent visits.</p>
      </div>

      <%= form_with scope: :loyalty, url: loyalty_path, class: "vstack gap-3" do |form| %>
        <div>
          <%= form.label :phone_number, class: "form-label" %>
          <div class="input-group">
            <span class="input-group-text phone-prefix">+91</span>
            <%= form.telephone_field :phone_number, class: "form-control", placeholder: "10 digit phone number", required: true, inputmode: "numeric", autocomplete: "tel-national", maxlength: 10, pattern: "\\d{10}", title: "Enter a 10 digit phone number", data: { phone_number_field: true } %>
          </div>
        </div>

        <%= form.submit "Check Points", class: "btn btn-primary w-100" %>
      <% end %>

      <section class="install-app-panel mt-4" data-pwa-install-panel data-install-source="loyalty_page" aria-labelledby="loyalty-install-app-title">
        <div class="d-flex align-items-start gap-3">
          <div class="install-app-icon" aria-hidden="true">
            <i class="ti ti-device-mobile-down"></i>
          </div>

          <div class="flex-grow-1">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
              <h2 id="loyalty-install-app-title" class="h6 mb-0">Install Fuel Loyalty</h2>
              <span class="badge text-bg-light border">Recommended</span>
            </div>

            <p class="small-muted mb-3" data-pwa-install-status>
              Add Fuel Loyalty to this device for faster access next time and a full-screen app experience.
            </p>

            <div class="d-grid gap-2">
              <button type="button" class="btn btn-outline-primary" data-pwa-install-button>
                <i class="ti ti-download me-1"></i>
                <span>Install App</span>
              </button>
              <p class="small-muted mb-0 d-none" data-pwa-install-help></p>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>
