<% content_for :title, "Shifts" %>

<div class="mb-4 page-header admin-shifts-header">
  <div class="page-intro mb-0">
    <h1>Shifts</h1>
    <p>Create reusable shift templates that staff can be assigned to before attendance is recorded.</p>
  </div>

  <div class="page-actions d-flex flex-wrap gap-2">
    <%= link_to "Staff", admin_staff_members_path, class: "btn btn-outline-secondary btn-sm" %>
    <%= link_to "Cycles", admin_shift_cycles_path, class: "btn btn-outline-secondary btn-sm" %>
    <%= button_tag "+",
      type: "button",
      class: "customer-details-quick-action admin-shifts-create-action",
      data: { bs_toggle: "modal", bs_target: "#addShiftTemplateModal" },
      aria: { label: "Add Shift" },
      title: "Add Shift" %>
  </div>
</div>

<% if @shift_templates.any? %>
  <div class="admin-shifts-card-grid">
    <% @shift_templates.each do |shift_template| %>
      <% modal_id = "editShiftTemplateModal-#{shift_template.id}" %>
      <% edit_shift_template = (@edit_shift_template&.id == shift_template.id ? @edit_shift_template : shift_template) %>

      <div class="card shadow-sm admin-shifts-card admin-shifts-card--cycle">
        <div class="card-body">
          <div class="customer-details-vehicle-row admin-shift-item admin-shift-item--cycle-card admin-shift-item--flush-details">
            <div class="admin-shift-item__top">
              <div class="admin-shift-item__heading">
                <span class="admin-shift-item__name"><%= shift_template.name %></span>
                <span class="admin-user-item__role <%= shift_template.active? ? "is-staff" : "" %>"><%= shift_template.active? ? "Active" : "Inactive" %></span>
              </div>

              <div class="admin-shift-item__side">
                <%= button_tag type: "button",
                  class: "customer-details-history-preview-action admin-shift-item__edit",
                  data: { bs_toggle: "modal", bs_target: "##{modal_id}" },
                  aria: { label: "Edit #{shift_template.name}" },
                  title: "Edit shift" do %>
                  <i class="ti ti-pencil" aria-hidden="true"></i>
                <% end %>
              </div>
            </div>

            <div class="admin-shift-item__details admin-shift-item__details--flush">
              <div class="admin-shift-item__detail">
                <span class="admin-shift-item__detail-label">Starts At</span>
                <strong class="admin-shift-item__detail-value"><%= shift_template.start_time_label %></strong>
              </div>

              <div class="admin-shift-item__detail">
                <span class="admin-shift-item__detail-label">Duration</span>
                <strong class="admin-shift-item__detail-value"><%= shift_template.duration_label %></strong>
              </div>

              <div class="admin-shift-item__detail">
                <span class="admin-shift-item__detail-label">Assigned Staff</span>
                <strong class="admin-shift-item__detail-value"><%= shift_template.shift_assignments.active.count %></strong>
              </div>

              <div class="admin-shift-item__detail">
                <span class="admin-shift-item__detail-label">Linked Cycles</span>
                <strong class="admin-shift-item__detail-value"><%= shift_template.shift_cycles.active.count %></strong>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="modal fade customer-details-modal admin-shifts-modal"
        id="<%= modal_id %>"
        tabindex="-1"
        aria-labelledby="<%= modal_id %>-label"
        aria-hidden="true"
        data-auto-open-modal="<%= @edit_shift_template&.id == shift_template.id %>">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
          <div class="modal-content confirm-modal-content customer-details-modal__content admin-shifts-modal__content">
            <div class="modal-header border-0 pb-0">
              <div>
                <h2 class="modal-title h5 mb-1" id="<%= modal_id %>-label">Edit Shift</h2>
                <p class="text-muted mb-0 small">Update the shift label, start time, duration, or active state.</p>
              </div>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
              <%= render "form",
                shift_template: edit_shift_template,
                form_url: admin_shift_template_path(shift_template),
                form_method: :patch,
                submit_label: "Update Shift" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card shadow-sm admin-shifts-card">
    <div class="card-body">
      <p class="admin-users-empty mb-0">No shift templates created yet.</p>
    </div>
  </div>
<% end %>

<div
  class="modal fade customer-details-modal admin-shifts-modal"
  id="addShiftTemplateModal"
  tabindex="-1"
  aria-labelledby="addShiftTemplateModalLabel"
  aria-hidden="true"
  data-auto-open-modal="<%= @shift_template.errors.any? %>">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content confirm-modal-content customer-details-modal__content admin-shifts-modal__content">
      <div class="modal-header border-0 pb-0">
        <div>
          <h2 class="modal-title h5 mb-1" id="addShiftTemplateModalLabel">Add Shift</h2>
          <p class="text-muted mb-0 small">Create a reusable shift start time and duration for staff planning and attendance.</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-3">
        <%= render "form",
          shift_template: @shift_template,
          form_url: admin_shift_templates_path,
          form_method: :post,
          submit_label: "Create Shift" %>
      </div>
    </div>
  </div>
</div>
