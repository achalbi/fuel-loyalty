<% if shift_template.errors.any? %>
  <div class="alert alert-danger">
    <%= shift_template.errors.full_messages.to_sentence %>
  </div>
<% end %>

<%= form_with model: [:admin, shift_template], url: form_url, method: form_method, local: true, class: "vstack gap-3" do |form| %>
  <div>
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control", maxlength: 80, required: true %>
  </div>

  <div class="row g-3">
    <div class="col-sm-6">
      <%= form.label :start_time, "Shift Start Time", class: "form-label" %>
      <%= form.time_field :start_time,
        value: shift_template.start_time_input_value,
        class: "form-control",
        required: true,
        step: 300 %>
    </div>

    <div class="col-sm-6">
      <%= form.label :duration_hours, "Shift Duration (hours)", class: "form-label" %>
      <%= form.number_field :duration_hours,
        value: shift_template.duration_hours,
        class: "form-control",
        min: 0.5,
        step: 0.25,
        required: true,
        placeholder: "Enter the total shift duration in hours" %>
    </div>
  </div>
  <p class="small-muted mb-0 mt-n2">Use hours like 6, 12, 24, or a custom value such as 7.5.</p>

  <div>
    <%= form.label :active, class: "form-label" %>
    <%= form.select :active,
      options_for_select([["Active", true], ["Inactive", false]], shift_template.active?),
      {},
      class: "form-select" %>
  </div>

  <div class="d-flex justify-content-end">
    <%= form.submit submit_label, class: "btn btn-primary" %>
  </div>
<% end %>
