<% content_for :title, @user.display_name %>

<div class="mb-4 page-header admin-users-header">
  <div class="page-intro mb-0">
    <h1><%= @user.display_name %></h1>
    <p>Review this user account, including the display name used in the app and the username used for login.</p>
  </div>
  <div class="page-actions d-flex flex-wrap gap-2">
    <%= link_to "Back", admin_users_path, class: "btn btn-outline-secondary btn-sm" %>
    <%= link_to "Edit", edit_admin_user_path(@user), class: "btn btn-primary btn-sm" %>
    <% if @user.staff? %>
      <%= button_to "Soft Delete",
        admin_staff_member_path(@user),
        method: :delete,
        class: "btn btn-outline-danger btn-sm",
        form_class: "d-inline-block",
        form: { data: { confirm_modal: true, confirm_message: "Attempt soft delete for #{@user.display_name}? Historical records will be kept. Active users must be deactivated first." } } %>
    <% end %>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-body">
    <div class="admin-staff-member__details admin-staff-member__details--flush">
      <div class="admin-staff-member__detail admin-user-detail">
        <span class="admin-staff-member__detail-label admin-user-detail__label">Name</span>
        <strong class="admin-staff-member__detail-value admin-user-detail__value"><%= @user.name %></strong>
      </div>
      <div class="admin-staff-member__detail admin-user-detail">
        <span class="admin-staff-member__detail-label admin-user-detail__label">Username</span>
        <strong class="admin-staff-member__detail-value admin-user-detail__value"><%= @user.username %></strong>
      </div>
      <div class="admin-staff-member__detail admin-user-detail">
        <span class="admin-staff-member__detail-label admin-user-detail__label">Role</span>
        <strong class="admin-staff-member__detail-value admin-user-detail__value"><%= @user.role.titleize %></strong>
      </div>
      <div class="admin-staff-member__detail admin-user-detail">
        <span class="admin-staff-member__detail-label admin-user-detail__label">Mobile</span>
        <strong class="admin-staff-member__detail-value admin-user-detail__value"><%= @user.display_phone_number || "Not set" %></strong>
      </div>
      <div class="admin-staff-member__detail admin-user-detail">
        <span class="admin-staff-member__detail-label admin-user-detail__label">Email</span>
        <strong class="admin-staff-member__detail-value admin-user-detail__value"><%= @user.explicit_email || "Not set" %></strong>
      </div>
      <div class="admin-staff-member__detail admin-user-detail">
        <span class="admin-staff-member__detail-label admin-user-detail__label">Status</span>
        <strong class="admin-staff-member__detail-value admin-user-detail__value"><%= @user.active? ? "Active" : "Inactive" %></strong>
      </div>
    </div>
  </div>
</div>
