<% content_for :title, "Staff" %>

<div class="mb-4 page-header admin-staff-header">
  <div class="page-intro mb-0">
    <h1>Staff</h1>
    <p>Track active staff, capture employee codes, and assign the shift each person should load under in attendance.</p>
  </div>

  <div class="page-actions d-flex flex-wrap gap-2">
    <%= link_to "Cycles", admin_shift_cycles_path, class: "btn btn-outline-secondary btn-sm" %>
    <%= link_to "Shifts", admin_shift_templates_path, class: "btn btn-outline-secondary btn-sm" %>
    <%= link_to "Attendance", new_admin_attendance_run_path, class: "btn btn-primary btn-sm" %>
  </div>
</div>

<div class="admin-staff-summary mb-4">
  <div class="card shadow-sm h-100 admin-staff-summary__item">
    <div class="card-body">
      <p class="small-muted mb-1">Active Staff</p>
      <h2 class="mb-0"><%= @active_staff_count %></h2>
    </div>
  </div>
  <div class="card shadow-sm h-100 admin-staff-summary__item">
    <div class="card-body">
      <p class="small-muted mb-1">Inactive Staff</p>
      <h2 class="mb-0"><%= @inactive_staff_count %></h2>
    </div>
  </div>
  <div class="card shadow-sm h-100 admin-staff-summary__item">
    <div class="card-body">
      <p class="small-muted mb-1">Unassigned Staff</p>
      <h2 class="mb-0"><%= @unassigned_staff_count %></h2>
    </div>
  </div>
</div>

<div class="card shadow-sm admin-staff-guide mb-4">
  <div class="card-body">
    <div class="admin-staff-guide__copy">
      <h2 class="h5 mb-1">Keep staff ready for attendance</h2>
      <p class="small-muted mb-0">Update who should appear in planning, assign the shift they should load under, and then use Attendance to mark present, absent, or replaced for the day.</p>
    </div>
  </div>
</div>

<% if @staff_members.any? %>
  <div class="admin-staff-list admin-staff-card-grid">
    <% @staff_members.each do |staff_member| %>
      <% profile_form_staff_member = (@edit_staff_member&.id == staff_member.id ? @edit_staff_member : staff_member) %>
      <% current_shift_assignment = staff_member.current_shift_assignment %>
      <% current_shift = staff_member.current_shift_template %>
      <% current_shift_cycle = staff_member.current_shift_cycle %>
      <% shift_assignment = if @assignment_form_user_id == staff_member.id
        @shift_assignment
      else
        ShiftAssignment.new(
          user: staff_member,
          active: true,
          shift_template: current_shift,
          notes: current_shift_assignment&.notes
        )
      end %>
      <% profile_modal_id = "editStaffProfileModal-#{staff_member.id}" %>
      <% shift_modal_id = "assignStaffShiftModal-#{staff_member.id}" %>

      <div class="card shadow-sm admin-staff-card admin-staff-card--member">
        <div class="card-body">
          <article class="admin-staff-member admin-staff-member--card admin-staff-member--flush-details">
            <div class="admin-staff-member__top">
              <div class="admin-staff-member__identity">
                <span class="avatar avatar-md rounded-circle bg-primary-subtle text-primary admin-staff-member__avatar">
                  <span class="avatar-initials"><%= staff_member.avatar_initial %></span>
                </span>

                <div class="admin-staff-member__main">
                  <div class="admin-staff-member__heading">
                    <span class="admin-staff-member__name"><%= staff_member.display_name %></span>
                  </div>
                  <% if staff_member.subtitle.present? %>
                    <p class="small-muted mb-0 admin-staff-member__subcopy"><%= staff_member.subtitle %></p>
                  <% end %>
                </div>
              </div>

              <div class="admin-staff-member__side">
                <div class="admin-staff-member__actions">
                  <%= button_tag type: "button",
                    class: "customer-details-history-preview-action admin-user-item__edit",
                    data: { bs_toggle: "modal", bs_target: "##{profile_modal_id}" },
                    aria: { label: "Edit profile for #{staff_member.display_name}" },
                    title: "Edit profile" do %>
                    <i class="ti ti-user-edit" aria-hidden="true"></i>
                  <% end %>

                  <%= button_tag type: "button",
                    class: "admin-staff-member__action admin-staff-member__action--primary",
                    data: { bs_toggle: "modal", bs_target: "##{shift_modal_id}" },
                    aria: { label: "Assign shift for #{staff_member.display_name}" },
                    title: "Assign shift" do %>
                    <i class="ti ti-clock-hour-4" aria-hidden="true"></i>
                    <span>Shift</span>
                  <% end %>

                  <%= button_to admin_staff_member_path(staff_member),
                    method: :delete,
                    class: "customer-details-history-preview-action admin-shift-item__delete",
                    form_class: "d-inline-block",
                    form: { data: { confirm_modal: true, confirm_message: "Attempt soft delete for #{staff_member.display_name}? Historical records will be kept. Active users must be deactivated first." } },
                    aria: { label: "Soft delete #{staff_member.display_name}" },
                    title: "Soft delete" do %>
                    <i class="ti ti-trash" aria-hidden="true"></i>
                  <% end %>
                </div>

                <span class="admin-user-item__role admin-staff-member__status <%= staff_member.active? ? "is-staff" : "" %>"><%= staff_member.active? ? "Active" : "Inactive" %></span>
              </div>
            </div>

            <div class="admin-staff-member__shift-card">
              <span class="admin-staff-member__shift-label">Assigned Shift</span>
              <strong class="admin-staff-member__shift-value"><%= current_shift.present? ? current_shift.name : "Unassigned" %></strong>
              <span class="admin-staff-member__shift-meta">
                <%= current_shift.present? ? [current_shift.schedule_label, current_shift_cycle&.name].compact.join(" · ") : "Assign a shift so this staff member loads under the correct attendance roster." %>
              </span>
            </div>

            <div class="admin-staff-member__details admin-staff-member__details--flush">
              <div class="admin-staff-member__detail">
                <span class="admin-staff-member__detail-label">Mobile</span>
                <strong class="admin-staff-member__detail-value"><%= staff_member.display_phone_number || "Not set" %></strong>
              </div>
              <div class="admin-staff-member__detail">
                <span class="admin-staff-member__detail-label">Employee Code</span>
                <strong class="admin-staff-member__detail-value"><%= staff_member.employee_code.presence || "Not set" %></strong>
              </div>
              <div class="admin-staff-member__detail">
                <span class="admin-staff-member__detail-label">Shift Cycle</span>
                <strong class="admin-staff-member__detail-value"><%= current_shift_cycle&.name || "No linked cycle" %></strong>
              </div>
              <div class="admin-staff-member__detail">
                <span class="admin-staff-member__detail-label">Planning Status</span>
                <strong class="admin-staff-member__detail-value"><%= staff_member.active? ? "Visible in attendance" : "Hidden from attendance" %></strong>
              </div>
            </div>
          </article>
        </div>
      </div>

      <div
        class="modal fade customer-details-modal admin-staff-modal"
        id="<%= profile_modal_id %>"
        tabindex="-1"
        aria-labelledby="<%= profile_modal_id %>-label"
        aria-hidden="true"
        data-auto-open-modal="<%= @edit_staff_member&.id == staff_member.id %>">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
          <div class="modal-content confirm-modal-content customer-details-modal__content admin-staff-modal__content">
            <div class="modal-header border-0 pb-0">
              <div>
                <h2 class="modal-title h5 mb-1" id="<%= profile_modal_id %>-label">Edit Staff Profile</h2>
                <p class="text-muted mb-0 small">Update the employee code and whether this staff member should appear in future planning.</p>
              </div>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3">
              <%= render "admin/staff_members/profile_form", staff_member: profile_form_staff_member %>
            </div>
          </div>
        </div>
      </div>

      <div
        class="modal fade customer-details-modal admin-staff-modal"
        id="<%= shift_modal_id %>"
        tabindex="-1"
        aria-labelledby="<%= shift_modal_id %>-label"
        aria-hidden="true"
        data-auto-open-modal="<%= @assignment_form_user_id == staff_member.id %>">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
          <div class="modal-content confirm-modal-content customer-details-modal__content admin-staff-modal__content">
            <div class="modal-header border-0 pb-0">
              <div>
                    <h2 class="modal-title h5 mb-1" id="<%= shift_modal_id %>-label">Assign Shift</h2>
                    <p class="text-muted mb-0 small">Choose the shift this staff member should load under. Linked shift cycles stay attached to the shift itself.</p>
                  </div>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-3">
                  <%= render "admin/staff_members/shift_assignment_form",
                    staff_member: staff_member,
                    shift_assignment: shift_assignment,
                    shift_templates: @shift_templates %>
                </div>
              </div>
            </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card shadow-sm admin-staff-card">
    <div class="card-body">
      <p class="admin-users-empty mb-0">No staff accounts available yet.</p>
    </div>
  </div>
<% end %>
