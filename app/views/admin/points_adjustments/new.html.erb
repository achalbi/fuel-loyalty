<% content_for :title, "Adjust Points" %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow-sm">
      <div class="card-body">
        <h1 class="h3 mb-3">Adjust Loyalty Points</h1>
        <p class="text-muted">Use positive points to add and negative points to deduct.</p>

        <%= form_with scope: :points_adjustment, url: admin_points_adjustments_path, class: "vstack gap-3" do |form| %>
          <div>
            <%= form.label :phone_number, class: "form-label" %>
            <div class="input-group">
              <span class="input-group-text phone-prefix">+91</span>
              <%= form.telephone_field :phone_number, class: "form-control", required: true, placeholder: "10 digit phone number", inputmode: "numeric", autocomplete: "tel-national", maxlength: 10, pattern: "\\d{10}", title: "Enter a 10 digit phone number", data: { phone_number_field: true } %>
            </div>
          </div>

          <div>
            <%= form.label :points, class: "form-label" %>
            <%= form.number_field :points, class: "form-control", required: true %>
          </div>

          <%= form.submit "Save Adjustment", class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
