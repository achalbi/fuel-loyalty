<% content_for :title, "Vehicle Types" %>

<div class="row g-4">
  <div class="col-lg-4">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <h1 class="h3 mb-3">Vehicle Types</h1>
        <p class="text-muted">Add vehicle types shown across customer and vehicle forms.</p>

        <%= render "form",
          vehicle_type: @vehicle_type,
          submit_label: "Add Vehicle Type",
          autofocus: true %>
      </div>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
          <div>
            <h2 class="h4 mb-1">Existing Vehicle Types</h2>
            <p class="text-muted mb-0">Edit names, hide vehicle types from new selections, or remove unused ones.</p>
          </div>
          <span class="badge rounded-pill text-bg-light border"><%= pluralize(@vehicle_types.count, "vehicle type") %></span>
        </div>

        <% if @vehicle_types.any? %>
          <div class="reward-rates-form vstack gap-3">
            <% @vehicle_types.each do |vehicle_type| %>
              <% vehicle_count = vehicle_type.vehicles.count %>

              <div class="reward-rate-row">
                <div class="reward-rate-copy">
                  <div class="reward-rate-title d-flex align-items-center gap-2">
                    <span class="vehicle-type-admin-icon" aria-hidden="true"><i class="ti <%= vehicle_type.icon_name %>"></i></span>
                    <span><%= vehicle_type.name %></span>
                  </div>
                  <p class="reward-rate-meta mb-0">
                    Short name: <strong><%= vehicle_type.short_name %></strong>.
                    App label: <strong><%= vehicle_type.app_label_source_short_name? ? "Short Name" : "Vehicle Type Name" %></strong>.
                    Icon: <strong><%= vehicle_type.icon_name %></strong>.
                    Code: <code><%= vehicle_type.code %></code>.
                    <%= vehicle_type.active? ? "Shown in app." : "Hidden from new selections." %>
                    <%= vehicle_count.positive? ? "Used by #{pluralize(vehicle_count, 'vehicle')}." : "Not used by any vehicles yet." %>
                  </p>
                </div>

                <div class="reward-rate-field d-flex flex-column align-items-end gap-2">
                  <span class="badge rounded-pill <%= vehicle_type.active? ? "text-bg-success" : "text-bg-secondary" %>"><%= vehicle_type.active? ? "Active" : "Inactive" %></span>

                  <div class="d-flex gap-2">
                    <%= link_to "Edit", edit_admin_vehicle_type_path(vehicle_type), class: "btn btn-outline-secondary btn-sm" %>
                    <%= button_to "Delete",
                      admin_vehicle_type_path(vehicle_type),
                      method: :delete,
                      class: "btn btn-outline-danger btn-sm",
                      form: {
                        class: "d-inline-block",
                        data: {
                          confirm_modal: true,
                          confirm_message: "Remove #{vehicle_type.name}?"
                        }
                      } %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="alert alert-light border mb-0">No vehicle types have been added yet.</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
