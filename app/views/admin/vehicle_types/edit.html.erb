<% content_for :title, "Edit Vehicle Type" %>

<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card shadow-sm">
      <div class="card-body">
        <h1 class="h3 mb-3">Edit Vehicle Type</h1>
        <p class="text-muted">Update the full name, short name, app label choice, and availability for this vehicle type.</p>

        <% vehicle_count = @vehicle_type.vehicles.count %>
        <% if vehicle_count.positive? %>
          <div class="alert alert-light border">
            This vehicle type is currently used by <%= pluralize(vehicle_count, "vehicle") %>, so it cannot be removed until those vehicles are updated.
          </div>
        <% end %>

        <%= render "form",
          vehicle_type: @vehicle_type,
          submit_label: "Save Vehicle Type",
          cancel_path: admin_vehicle_types_path,
          autofocus: true %>
      </div>
    </div>
  </div>
</div>
