<% content_for :title, "Attendance" %>

<div class="mb-4 page-header admin-attendance-header">
  <div class="page-intro admin-attendance-header__intro mb-0">
    <div class="admin-attendance-header__topline">
      <h1>Attendance</h1>
      <div class="page-actions d-flex flex-wrap gap-2">
        <%= link_to "New Attendance", new_admin_attendance_run_path, class: "btn btn-primary btn-sm" %>
      </div>
    </div>
    <p>Review saved attendance windows, open any recorded shift, and start a new attendance run when needed.</p>
  </div>
</div>

<div class="card shadow-sm admin-transactions-filter mb-4">
  <div class="card-body">
    <%= form_with url: admin_attendance_runs_path, method: :get, local: true, class: "admin-transactions-filter__form admin-attendance-filter__form" do |form| %>
      <%= hidden_field_tag :filter, @record_filter %>

      <div class="admin-transactions-filter__topline admin-attendance-filter__topline">
        <div class="admin-transactions-filter__group">
          <span class="admin-transactions-filter__label">Record State</span>
          <div class="dashboard-filter-chips">
            <%= link_to "All",
              admin_attendance_runs_path(filter: "all", start_date: @current_start_date&.iso8601, end_date: @current_end_date&.iso8601),
              class: "dashboard-filter-chip #{'is-active' if @record_filter == 'all'}" %>
            <%= link_to "Valid",
              admin_attendance_runs_path(filter: "valid", start_date: @current_start_date&.iso8601, end_date: @current_end_date&.iso8601),
              class: "dashboard-filter-chip #{'is-active' if @record_filter == 'valid'}" %>
            <%= link_to "Invalid",
              admin_attendance_runs_path(filter: "invalid", start_date: @current_start_date&.iso8601, end_date: @current_end_date&.iso8601),
              class: "dashboard-filter-chip #{'is-active' if @record_filter == 'invalid'}" %>
          </div>

        </div>
        <div class="admin-transactions-filter__group admin-transactions-filter__range admin-attendance-filter__range">
          <span class="admin-transactions-filter__label">Attendance Date</span>
          <div class="admin-transactions-filter__range-fields">
            <div>
              <%= form.label :start_date, "From", class: "visually-hidden" %>
              <%= form.date_field :start_date,
                value: @current_start_date&.iso8601,
                max: Date.current.iso8601,
                class: "form-control admin-transactions-filter__date",
                onchange: "this.form.requestSubmit()" %>
            </div>
            <div>
              <%= form.label :end_date, "To", class: "visually-hidden" %>
              <%= form.date_field :end_date,
                value: @current_end_date&.iso8601,
                max: Date.current.iso8601,
                class: "form-control admin-transactions-filter__date",
                onchange: "this.form.requestSubmit()" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<% if @attendance_runs.any? %>
  <div class="admin-attendance-run-list">
    <% @attendance_runs.each do |attendance_run| %>
      <% status_counts = AttendanceEntry.statuses.keys.index_with { |status| attendance_run.status_counts.fetch(status, 0) } %>
      <% visible_status_summary = status_counts.filter_map { |status, count| "#{status.humanize} #{count}" if count.positive? } %>
      <div class="card shadow-sm admin-attendance-run-card">
        <div class="card-body">
          <div class="admin-shift-item admin-attendance-run-item admin-shift-item--flush-details">
            <div class="admin-shift-item__top">
              <div class="admin-attendance-item__main">
                <div class="admin-attendance-item__heading">
                  <span class="admin-attendance-item__name"><%= attendance_run.shift_name_snapshot %></span>
                  <span class="badge text-bg-light border"><%= pluralize(attendance_run.attendance_entries.size, "staff") %></span>
                </div>
                <p class="small-muted mb-0"><%= "#{l(attendance_run.starts_at, format: "%d %b · %I:%M %p")} to #{l(attendance_run.ends_at, format: "%d %b · %I:%M %p")}" %></p>
              </div>
              <div class="admin-attendance-run__actions">
                <div class="admin-attendance-run__action-row">
                  <%= link_to admin_attendance_run_path(attendance_run), class: "customer-details-history-preview-action admin-attendance-run__open", title: "Open attendance run", aria: { label: "Open attendance run #{attendance_run.id}" } do %>
                    <i class="ti ti-eye" aria-hidden="true"></i>
                  <% end %>
                  <% if attendance_run.stale? %>
                    <%= button_to admin_attendance_run_path(attendance_run),
                      method: :delete,
                      class: "customer-details-history-preview-action admin-shift-item__delete",
                      form_class: "d-inline-block",
                      form: { data: { confirm_modal: true, confirm_message: "Delete this invalid attendance record?" } },
                      aria: { label: "Delete invalid attendance run #{attendance_run.id}" },
                      title: "Delete invalid attendance" do %>
                      <i class="ti ti-trash" aria-hidden="true"></i>
                    <% end %>
                  <% end %>
                </div>
                <% if attendance_run.stale? %>
                  <span class="badge admin-attendance-run__state-badge">Invalid</span>
                <% end %>
              </div>
            </div>

            <div class="admin-shift-item__details admin-shift-item__details--flush">
              <div class="admin-shift-item__detail">
                <span class="admin-shift-item__detail-label">Recorded By</span>
                <strong class="admin-shift-item__detail-value"><%= attendance_run.recorded_by.display_name %></strong>
              </div>

              <div class="admin-shift-item__detail">
                <span class="admin-shift-item__detail-label">Saved At</span>
                <strong class="admin-shift-item__detail-value"><%= l(attendance_run.created_at, format: "%d %b · %I:%M %p") %></strong>
              </div>

              <div class="admin-shift-item__detail">
                <span class="admin-shift-item__detail-label">Status</span>
                <strong class="admin-shift-item__detail-value"><%= attendance_run.record_state_label %></strong>
              </div>

              <div class="admin-shift-item__detail">
                <span class="admin-shift-item__detail-label">Status Summary</span>
                <strong class="admin-shift-item__detail-value admin-attendance-run__summary">
                  <%= visible_status_summary.join(" · ") %>
                </strong>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="customer-details-ledger-pagination admin-attendance-pagination">
    <div class="customer-details-ledger-pagination__summary admin-attendance-pagination__summary">
      Showing <strong><%= @showing_from %>-<%= @showing_to %></strong> of <strong><%= @total_attendance_runs %></strong> attendance records
    </div>

    <% if @total_pages > 1 %>
      <div class="customer-details-ledger-pagination__actions admin-attendance-pagination__actions">
        <% if @current_page > 1 %>
          <%= link_to admin_attendance_runs_path(filter: @record_filter, start_date: @current_start_date&.iso8601, end_date: @current_end_date&.iso8601, page: @current_page - 1),
            class: "admin-attendance-pagination__button" do %>
            <i class="ti ti-chevron-left" aria-hidden="true"></i>
            <span>Previous</span>
          <% end %>
        <% else %>
          <span class="admin-attendance-pagination__button is-disabled" aria-disabled="true">
            <i class="ti ti-chevron-left" aria-hidden="true"></i>
            <span>Previous</span>
          </span>
        <% end %>

        <span class="customer-details-ledger-pagination__status admin-attendance-pagination__status">
          <span class="admin-attendance-pagination__status-label">Page</span>
          <strong><%= @current_page %></strong>
          <span class="admin-attendance-pagination__status-separator">of</span>
          <span><%= @total_pages %></span>
        </span>

        <% if @current_page < @total_pages %>
          <%= link_to admin_attendance_runs_path(filter: @record_filter, start_date: @current_start_date&.iso8601, end_date: @current_end_date&.iso8601, page: @current_page + 1),
            class: "admin-attendance-pagination__button" do %>
            <span>Next</span>
            <i class="ti ti-chevron-right" aria-hidden="true"></i>
          <% end %>
        <% else %>
          <span class="admin-attendance-pagination__button is-disabled" aria-disabled="true">
            <span>Next</span>
            <i class="ti ti-chevron-right" aria-hidden="true"></i>
          </span>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card shadow-sm">
    <div class="card-body">
      <h2 class="h5 mb-2">No attendance found for the current filters</h2>
      <p class="small-muted mb-0">Try another filter or start a new attendance run to see recorded shift windows here.</p>
    </div>
  </div>
<% end %>
