<% content_for :title, "Admin Dashboard" %>
<% content_for :head do %>
  <%= javascript_include_tag "chart.umd.js", "data-turbo-track": "reload", defer: true %>
  <%= javascript_include_tag "admin_dashboard.js", "data-turbo-track": "reload", defer: true %>
<% end %>

<% summary_by_key = @dashboard_payload.fetch(:summary, []).index_by { |item| item[:key] } %>
<% charts_payload = @dashboard_payload.fetch(:charts, {}) %>
<% rewards_payload = @dashboard_payload.fetch(:rewards, {}) %>

<div
  class="dashboard-root"
  data-dashboard-root
  data-dashboard-endpoint="<%= data_admin_dashboard_path %>">
  <script type="application/json" data-dashboard-payload><%= raw(json_escape(@dashboard_payload.to_json)) %></script>

  <div class="dashboard-toolbar">
    <div class="page-intro mb-0">
      <h1>Overview Dashboard</h1>
      <p>Track station performance, customer activity, and loyalty engagement from one operating view.</p>
    </div>

    <%= form_with url: admin_dashboard_path, method: :get, local: true, class: "dashboard-filter-form", data: { dashboard_filters: true } do |form| %>
      <%= form.hidden_field :preset, value: @dashboard_filters[:preset], data: { dashboard_preset_input: true } %>
      <%= form.hidden_field :fuel_type, value: @dashboard_filters[:fuel_type], data: { dashboard_fuel_type_input: true } %>

      <div class="dashboard-filter-form__field dashboard-filter-form__field--full">
        <div class="dashboard-filter-form__field-header">
          <span class="form-label">Quick Range</span>
          <div class="dashboard-filter-form__header-actions">
            <button type="button" class="btn btn-primary" data-dashboard-download>
              <i class="ti ti-file-type-pdf me-1" aria-hidden="true"></i>
              Download PDF
            </button>
            <%= link_to "Reset", admin_dashboard_path, class: "btn btn-outline-secondary" %>
          </div>
        </div>
        <div class="dashboard-filter-chips">
          <% @dashboard_filters[:presets].each do |preset| %>
            <% active = @dashboard_filters[:preset].to_s == preset[:value].to_s %>
            <button
              type="button"
              class="dashboard-filter-chip <%= "is-active" if active %>"
              data-dashboard-preset-button="<%= preset[:value] %>"
              data-range-start="<%= preset[:start_date] %>"
              data-range-end="<%= preset[:end_date] %>"
              aria-pressed="<%= active %>">
              <%= preset[:label] %>
            </button>
          <% end %>
        </div>
      </div>

      <div class="dashboard-filter-form__field">
        <%= form.label :start_date, "From", class: "form-label" %>
        <%= form.date_field :start_date, value: @dashboard_filters[:start_date], class: "form-control", data: { dashboard_date_filter: true } %>
      </div>

      <div class="dashboard-filter-form__field">
        <%= form.label :end_date, "To", class: "form-label" %>
        <%= form.date_field :end_date, value: @dashboard_filters[:end_date], class: "form-control", data: { dashboard_date_filter: true } %>
      </div>

      <div class="dashboard-filter-form__field">
        <%= form.label :segment, "Customer Segment", class: "form-label" %>
        <%= form.select :segment, options_for_select(@dashboard_filters[:segments].map { |item| [item[:label], item[:value]] }, @dashboard_filters[:segment]), {}, class: "form-select", data: { dashboard_select_filter: true } %>
      </div>

      <div class="dashboard-filter-form__field dashboard-filter-form__field--full">
        <span class="form-label">Fuel Type</span>
        <div class="dashboard-filter-chips">
          <% @dashboard_filters[:fuel_types].each do |fuel_option| %>
            <% active = @dashboard_filters[:fuel_type].to_s == fuel_option[:value].to_s %>
            <button
              type="button"
              class="dashboard-filter-chip <%= "is-active" if active %>"
              data-dashboard-fuel-button="<%= fuel_option[:value] %>"
              aria-pressed="<%= active %>">
              <%= fuel_option[:label] %>
            </button>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <section class="dashboard-export-summary" data-dashboard-export-summary aria-label="Dashboard export summary">
    <div class="dashboard-export-summary__header">
      <div>
        <h2>Overview Dashboard Export</h2>
        <p class="small-muted mb-0">Filter context captured with the current chart snapshot.</p>
      </div>
      <span class="badge rounded-pill text-bg-light border">PDF</span>
    </div>

    <div class="dashboard-export-summary__grid">
      <div class="dashboard-export-summary__item">
        <span>Range</span>
        <strong data-dashboard-export-range><%= @dashboard_payload.dig(:meta, :range_label) %></strong>
      </div>
      <div class="dashboard-export-summary__item">
        <span>Quick Range</span>
        <strong data-dashboard-export-preset><%= @dashboard_filters[:presets].find { |item| item[:value].to_s == @dashboard_filters[:preset].to_s }&.dig(:label) || "Custom range" %></strong>
      </div>
      <div class="dashboard-export-summary__item">
        <span>Segment</span>
        <strong data-dashboard-export-segment><%= @dashboard_payload.dig(:meta, :segment_label) %></strong>
      </div>
      <div class="dashboard-export-summary__item">
        <span>Fuel Type</span>
        <strong data-dashboard-export-fuel-type><%= @dashboard_payload.dig(:meta, :fuel_type_label) %></strong>
      </div>
      <div class="dashboard-export-summary__item dashboard-export-summary__item--wide">
        <span>Generated</span>
        <strong data-dashboard-export-generated-at><%= l(Time.zone.parse(@dashboard_payload.dig(:meta, :generated_at).to_s) || Time.current, format: :long) rescue l(Time.current, format: :long) %></strong>
      </div>
    </div>
  </section>

  <div class="dashboard-meta-row">
    <span class="badge rounded-pill text-bg-light border" data-dashboard-range-label><%= @dashboard_payload.dig(:meta, :range_label) %></span>
    <span class="small-muted" data-dashboard-segment-label><%= @dashboard_payload.dig(:meta, :segment_label) %></span>
    <span class="small-muted" data-dashboard-fuel-type-label>Fuel type: <%= @dashboard_payload.dig(:meta, :fuel_type_label) %></span>
  </div>

  <section class="dashboard-section">
    <div class="dashboard-section__header">
      <div>
        <h2>KPI Overview</h2>
        <p class="small-muted mb-0">Snapshot of member activity and commercial performance for the selected period.</p>
      </div>
    </div>

    <div class="dashboard-kpi-grid">
      <% dashboard_kpi_cards.each do |card| %>
        <%= render partial: "kpi_card", locals: { card: card, metric: summary_by_key[card[:key]] } %>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="dashboard-section__header">
      <div>
        <h2>Trends</h2>
        <p class="small-muted mb-0">Daily movement of visits, revenue, loyalty issuance, and active customers.</p>
      </div>
    </div>

    <div class="dashboard-chart-grid">
      <% dashboard_chart_cards.first(4).each do |chart| %>
        <% chart_state = charts_payload[chart[:key].to_sym] || {} %>
        <%= render partial: "chart_panel", locals: { chart: chart, badge_label: chart_state.dig(:comparison, :label), badge_direction: chart_state.dig(:comparison, :direction) } %>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="dashboard-section__header">
      <div>
        <h2>Customer Insights</h2>
        <p class="small-muted mb-0">Understand acquisition mix and how often members come back.</p>
      </div>
    </div>

    <div class="dashboard-chart-grid dashboard-chart-grid--insights">
      <% dashboard_chart_cards[4, 2].each do |chart| %>
        <% chart_state = charts_payload[chart[:key].to_sym] || {} %>
        <%= render partial: "chart_panel", locals: { chart: chart, badge_label: chart_state.dig(:comparison, :label), badge_direction: chart_state.dig(:comparison, :direction) } %>
      <% end %>
    </div>

    <div class="dashboard-leaderboard-grid">
      <% dashboard_customer_leaderboards.each do |card| %>
        <% leaderboard_state = charts_payload[card[:key].to_sym] || {} %>
        <%= render partial: "leaderboard_panel", locals: { card: card, payload: leaderboard_state } %>
      <% end %>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="dashboard-section__header">
      <div>
        <h2>Rewards Insights</h2>
        <p class="small-muted mb-0">Measure redemption demand and the share of issued points already used.</p>
      </div>
    </div>

    <div class="dashboard-rewards-grid">
      <% rewards_chart = dashboard_chart_cards[6] %>
      <% rewards_chart_state = charts_payload[rewards_chart[:key].to_sym] || {} %>
      <%= render partial: "chart_panel", locals: { chart: rewards_chart, height: 300, badge_label: rewards_chart_state.dig(:comparison, :label), badge_direction: rewards_chart_state.dig(:comparison, :direction) } %>

      <div class="card dashboard-insight-card">
        <div class="card-body">
          <div class="dashboard-insight-card__header">
            <div>
              <h2 class="h5 mb-1">Redemption Rate</h2>
              <p class="small-muted mb-0">Redeemed points as a share of issued points in the selected period.</p>
            </div>
            <span class="badge rounded-pill text-bg-light border">Loyalty Health</span>
          </div>

          <div class="dashboard-redemption-rate">
            <div class="dashboard-redemption-rate__value" data-redemption-rate-value><%= number_to_percentage(rewards_payload[:redemption_rate].to_f, precision: 1, strip_insignificant_zeros: true) %></div>
            <div class="dashboard-redemption-rate__meter">
              <span data-redemption-rate-bar style="width: <%= [rewards_payload[:redemption_rate].to_f, 100].min %>%"></span>
            </div>
            <div class="dashboard-redemption-rate__meta">
              <div>
                <span class="small-muted">Issued</span>
                <strong data-redemption-issued><%= number_with_delimiter(rewards_payload[:issued_points].to_i) %></strong>
              </div>
              <div>
                <span class="small-muted">Redeemed</span>
                <strong data-redemption-redeemed><%= number_with_delimiter(rewards_payload[:redeemed_points].to_i) %></strong>
              </div>
            </div>
            <p class="small-muted mb-0" data-redemption-note><%= @dashboard_payload.dig(:rewards, :note) %></p>
          </div>

          <div class="dashboard-skeleton dashboard-skeleton--insight" data-dashboard-skeleton aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="dashboard-section">
    <div class="dashboard-section__header">
      <div>
        <h2>Behavior Analytics</h2>
        <p class="small-muted mb-0">Spot time-of-day and day-of-week patterns that shape staffing and campaigns.</p>
      </div>
    </div>

    <div class="dashboard-chart-grid dashboard-chart-grid--behavior">
      <% dashboard_chart_cards.last(2).each do |chart| %>
        <% chart_state = charts_payload[chart[:key].to_sym] || {} %>
        <%= render partial: "chart_panel", locals: { chart: chart, badge_label: chart_state.dig(:comparison, :label), badge_direction: chart_state.dig(:comparison, :direction) } %>
      <% end %>
    </div>
  </section>
</div>
