<script type="module">
  import { getApps, initializeApp } from "https://www.gstatic.com/firebasejs/<%= FirebaseAppConfig::FIREBASE_SDK_VERSION %>/firebase-app.js";
  import { getAnalytics, isSupported as analyticsIsSupported } from "https://www.gstatic.com/firebasejs/<%= FirebaseAppConfig::FIREBASE_SDK_VERSION %>/firebase-analytics.js";
  import { getMessaging, getToken as getMessagingToken, isSupported as messagingIsSupported, onMessage as onForegroundMessage } from "https://www.gstatic.com/firebasejs/<%= FirebaseAppConfig::FIREBASE_SDK_VERSION %>/firebase-messaging.js";

  const settings = window.fuelLoyaltyPushSettings || {};
  const firebaseConfig = settings.firebaseConfig || {};
  const app = getApps()[0] || initializeApp(firebaseConfig);
  let messagingPromise = null;
  let foregroundListenerAttached = false;
  const defaultNotificationIcon = "/notification-pump-icon.svg";
  const defaultNotificationBadge = "/notification-pump-badge.svg";

  const showForegroundNotification = async (payload) => {
    if (!("Notification" in window) || window.Notification.permission !== "granted") return;

    const notification = payload.notification || {};
    const data = payload.data || {};
    const fcmOptions = payload.fcmOptions || {};
    const title = notification.title || data.title || "Ace Fuel Loyalty";
    const body = notification.body || data.message || "";
    const options = {
      body,
      icon: notification.icon || defaultNotificationIcon,
      badge: notification.badge || defaultNotificationBadge,
      tag: data.notification_id || "fuel-loyalty-broadcast",
      data: {
        link: fcmOptions.link || data.link || settings.defaultLink || "/loyalty"
      }
    };

    const registration = await navigator.serviceWorker.getRegistration("/");
    if (registration) {
      await registration.showNotification(title, options);
      return;
    }

    new Notification(title, options);
  };

  const firebaseBridge = {
    app,
    analytics: null,
    async attachForegroundListener() {
      const messaging = await this.getMessaging();
      if (!messaging || foregroundListenerAttached) return;

      foregroundListenerAttached = true;
      onForegroundMessage(messaging, (payload) => {
        window.dispatchEvent(new CustomEvent("fuel-loyalty:push-message", { detail: payload }));
        showForegroundNotification(payload).catch(() => {});
      });
    },
    async getMessaging() {
      if (!settings.vapidKey) return null;

      if (!messagingPromise) {
        messagingPromise = messagingIsSupported()
          .then((supported) => supported ? getMessaging(app) : null)
          .catch(() => null);
      }

      return messagingPromise;
    },
    async getToken(options = {}) {
      const messaging = await this.getMessaging();
      if (!messaging) return null;

      return getMessagingToken(messaging, options);
    }
  };

  window.fuelLoyaltyFirebase = firebaseBridge;
  window.__resolveFuelLoyaltyFirebaseReady?.(firebaseBridge);
  firebaseBridge.attachForegroundListener().catch(() => {});

  if (firebaseConfig.measurementId) {
    analyticsIsSupported()
      .then((supported) => {
        if (supported) {
          firebaseBridge.analytics = getAnalytics(app);
        }
      })
      .catch(() => {});
  }
</script>
