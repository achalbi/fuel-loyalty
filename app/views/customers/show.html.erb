<% content_for :title, "Customer Details" %>
<% persisted_vehicles = @customer.vehicles.select(&:persisted?) %>

<div class="d-flex justify-content-between align-items-center mb-4 summary-header">
  <div>
    <div class="d-flex align-items-center gap-2 mb-1">
      <h1 class="h3 mb-0"><%= @customer.display_name %></h1>
      <span class="badge rounded-pill <%= @customer.active? ? "text-bg-success" : "text-bg-secondary" %>"><%= @customer.status_label %></span>
    </div>
    <p class="text-muted mb-0">Phone: <%= @customer.phone_number %></p>
  </div>
  <div class="text-end d-flex flex-column align-items-end gap-2 summary-actions">
    <div class="summary-metric">
      <div class="display-6 fw-bold"><%= @customer.total_points %></div>
      <div class="text-muted">Current Points</div>
    </div>

    <% if policy(@customer).update? %>
      <%= link_to "Edit Customer", edit_customer_path(@customer), class: "btn btn-primary" %>
    <% end %>

    <% if policy(@customer).activate? && !@customer.active? %>
      <%= button_to "Mark Active", activate_staff_customer_path(@customer), method: :patch, class: "btn btn-success" %>
    <% end %>

    <% if policy(@customer).deactivate? && @customer.active? %>
      <%= button_to "Mark Inactive", deactivate_staff_customer_path(@customer), method: :patch, class: "btn btn-outline-secondary", form: { data: { turbo_confirm: "Mark this customer as inactive?" } } %>
    <% end %>

    <% if policy(@customer).destroy? %>
      <%= button_to "Delete Customer", admin_customer_path(@customer), method: :delete, class: "btn btn-outline-danger", form: { data: { confirm_modal: true, confirm_message: "Remove this customer?" } } %>
    <% end %>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-7">
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h5">Recent Transactions</h2>
        <% if @customer.transactions.any? %>
          <div class="table-responsive">
            <table class="table responsive-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Vehicle</th>
                  <th>Amount</th>
                  <th>Handled By</th>
                </tr>
              </thead>
              <tbody>
                <% @customer.recent_transactions(10).each do |transaction| %>
                  <tr>
                    <td data-label="Date"><%= l(transaction.created_at, format: :short) %></td>
                    <td data-label="Vehicle"><%= transaction.vehicle&.vehicle_number || "N/A" %></td>
                    <td data-label="Amount"><%= number_to_currency(transaction.fuel_amount, unit: "₹") %></td>
                    <td data-label="Handled By"><%= transaction.user.email %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="text-muted mb-0">No transactions recorded yet.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h5">Vehicles</h2>
        <% if persisted_vehicles.any? %>
          <ul class="list-group mb-4">
            <% persisted_vehicles.each do |vehicle| %>
              <li class="list-group-item">
                <div class="d-flex justify-content-between align-items-start gap-3 vehicle-row">
                  <div class="vehicle-meta">
                    <div class="fw-semibold"><%= vehicle.vehicle_number %></div>
                    <div class="small text-muted"><%= vehicle.display_fuel_type %> | <%= vehicle.display_vehicle_kind %></div>
                  </div>

                  <% if policy(@customer).update? %>
                    <div class="table-action-group vehicle-action-group">
                      <%= link_to "Edit", edit_customer_vehicle_path(@customer, vehicle), class: "btn btn-sm btn-outline-primary" %>
                      <%= button_to "Delete", customer_vehicle_path(@customer, vehicle), method: :delete, class: "btn btn-sm btn-outline-danger", form: { data: { confirm_modal: true, confirm_message: "Remove this vehicle?" } } %>
                    </div>
                  <% end %>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted">No vehicles registered yet.</p>
        <% end %>

        <% if policy(@customer).update? %>
          <div class="mb-4">
            <h3 class="h6">Add Vehicle</h3>
            <%= render "vehicles/form",
              customer: @customer,
              vehicle: @vehicle,
              field_label: "Vehicle Number",
              submit_label: "Add Vehicle",
              submit_class: "btn btn-outline-primary" %>
          </div>
        <% end %>

        <h2 class="h5">Points Ledger</h2>
        <% if @customer.points_ledgers.any? %>
          <ul class="list-group">
            <% @customer.points_ledgers.order(created_at: :desc).limit(10).each do |entry| %>
              <li class="list-group-item d-flex justify-content-between align-items-center gap-3 stack-mobile">
                <span><%= entry.entry_type.humanize %></span>
                <span class="<%= entry.points.positive? ? "text-success" : "text-danger" %>"><%= entry.points %></span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No ledger entries yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
