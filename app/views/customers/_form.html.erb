<% modal_context = local_assigns[:context].to_s == "modal" %>
<% show_back_cancel_button = local_assigns[:show_back_cancel_button] %>
<% cancel_fallback_path = local_assigns[:cancel_fallback_path] %>
<% hidden_fields = local_assigns[:hidden_fields] || {} %>
<% selected_fuel_type = params.dig(customer.model_name.param_key, :fuel_type).presence %>
<% selected_vehicle_kind = params.dig(customer.model_name.param_key, :vehicle_kind).presence %>
<% fuel_type_options = FuelType.active_options %>
<% vehicle_type_options = VehicleType.active_options %>
<% vehicle_type_icons = VehicleType.icon_map_for(vehicle_type_options.map(&:last)) %>

<% form_markup = capture do %>
  <%= form_with model: customer, url: form_url, method: form_method, class: "vstack gap-3" do |form| %>
    <% if customer.errors.any? %>
      <div class="alert alert-danger">
        <%= customer.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>

    <div>
      <%= form.label :phone_number, class: "form-label" %>
      <div class="input-group">
        <span class="input-group-text phone-prefix">+91</span>
        <%= form.telephone_field :phone_number, class: "form-control", required: true, placeholder: "10 digit phone number", inputmode: "numeric", autocomplete: "tel-national", maxlength: 10, pattern: "\\d{10}", title: "Enter a 10 digit phone number", data: { phone_number_field: true } %>
      </div>
    </div>

    <% if include_vehicle_fields %>
      <div>
        <%= form.label :vehicle_number, "Initial Vehicle Number", class: "form-label" %>
        <%= form.text_field :vehicle_number, class: "form-control" %>
        <div class="form-text">You can add more vehicles after the customer record is created.</div>
      </div>

      <div>
        <%= render "shared/fuel_type_radio_group",
          legend: "Fuel Type",
          input_name: "customer[fuel_type]",
          options: fuel_type_options,
          selected_value: selected_fuel_type,
          field_id_prefix: "customer_fuel_type",
          errors: customer.errors[:fuel_type],
          hint: "Only active fuel types appear here." %>
      </div>

      <div>
        <%= render "shared/fuel_type_radio_group",
          legend: "Vehicle Type",
          input_name: "customer[vehicle_kind]",
          options: vehicle_type_options,
          icons_by_value: vehicle_type_icons,
          selected_value: selected_vehicle_kind,
          field_id_prefix: "customer_vehicle_kind",
          errors: customer.errors[:vehicle_kind],
          hint: "Only active vehicle types appear here.",
          empty_message: "No active vehicle types are available right now." %>
      </div>
    <% end %>

    <% hidden_fields.each do |field_name, field_value| %>
      <%= hidden_field_tag field_name, field_value %>
    <% end %>

    <div class="d-flex gap-2">
      <%= form.submit submit_label, class: "btn btn-primary" %>
      <% if modal_context %>
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
      <% elsif show_back_cancel_button %>
        <button
          type="button"
          class="btn btn-outline-secondary"
          data-cancel-back-button="true"
          data-fallback-path="<%= cancel_fallback_path %>"
          onclick="if (window.history.length > 1) { window.history.back(); } else { window.location.href = this.dataset.fallbackPath; }">Cancel</button>
      <% end %>
    </div>
  <% end %>
<% end %>

<% if modal_context %>
  <div class="admin-customers-form admin-customers-form--modal">
    <%= form_markup %>
  </div>
<% else %>
  <div class="row justify-content-center">
    <div class="col-md-7">
      <div class="card shadow-sm">
        <div class="card-body">
          <h1 class="h3 mb-3"><%= title %></h1>
          <%= form_markup %>
        </div>
      </div>
    </div>
  </div>
<% end %>
