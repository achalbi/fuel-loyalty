<% modal_context = local_assigns[:context].to_s == "modal" %>

<% form_markup = capture do %>
  <%= form_with model: customer, url: form_url, method: form_method, class: "vstack gap-3" do |form| %>
    <% if customer.errors.any? %>
      <div class="alert alert-danger">
        <%= customer.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>

    <div>
      <%= form.label :phone_number, class: "form-label" %>
      <div class="input-group">
        <span class="input-group-text phone-prefix">+91</span>
        <%= form.telephone_field :phone_number, class: "form-control", required: true, placeholder: "10 digit phone number", inputmode: "numeric", autocomplete: "tel-national", maxlength: 10, pattern: "\\d{10}", title: "Enter a 10 digit phone number", data: { phone_number_field: true } %>
      </div>
    </div>

    <% if include_vehicle_fields %>
      <div>
        <%= form.label :vehicle_number, "Initial Vehicle Number", class: "form-label" %>
        <%= form.text_field :vehicle_number, class: "form-control" %>
        <div class="form-text">You can add more vehicles after the customer record is created.</div>
      </div>

      <div>
        <%= form.label :fuel_type, "Fuel Type", class: "form-label" %>
        <%= form.select :fuel_type, Vehicle::FUEL_TYPE_OPTIONS, { prompt: "Select fuel type" }, class: "form-select" %>
      </div>

      <div>
        <%= form.label :vehicle_kind, "Vehicle Type", class: "form-label" %>
        <%= form.select :vehicle_kind, Vehicle::VEHICLE_KIND_OPTIONS, { prompt: "Select vehicle type" }, class: "form-select" %>
      </div>
    <% end %>

    <div class="d-flex gap-2">
      <%= form.submit submit_label, class: "btn btn-primary" %>
      <% if modal_context %>
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
      <% end %>
    </div>
  <% end %>
<% end %>

<% if modal_context %>
  <div class="admin-customers-form admin-customers-form--modal">
    <%= form_markup %>
  </div>
<% else %>
  <div class="row justify-content-center">
    <div class="col-md-7">
      <div class="card shadow-sm">
        <div class="card-body">
          <h1 class="h3 mb-3"><%= title %></h1>
          <%= form_markup %>
        </div>
      </div>
    </div>
  </div>
<% end %>
