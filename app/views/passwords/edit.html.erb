<% content_for :title, "Change Password" %>

<div class="d-flex justify-content-between align-items-center mb-4 page-header">
  <div class="page-intro mb-0">
    <h1>Change Password</h1>
    <p>Update your sign-in password for this account. You will need your current password to confirm the change.</p>
  </div>
</div>

<div class="card template-form-card mx-auto">
  <div class="card-body">
    <% if @user.errors.any? %>
      <div class="alert alert-danger"><%= @user.errors.full_messages.to_sentence %></div>
    <% end %>

    <%= form_with model: @user, url: password_path, method: :patch, class: "vstack gap-3" do |form| %>
      <div>
        <%= form.label :current_password, class: "form-label" %>
        <%= form.password_field :current_password, autocomplete: "current-password", class: "form-control", required: true %>
      </div>

      <div>
        <%= form.label :password, "New password", class: "form-label" %>
        <%= form.password_field :password, autocomplete: "new-password", class: "form-control", required: true %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirm new password", class: "form-label" %>
        <%= form.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", required: true %>
      </div>

      <div class="d-flex flex-wrap gap-2">
        <%= form.submit "Update Password", class: "btn btn-primary" %>
        <%= link_to "Cancel", (current_user.admin? ? admin_dashboard_path : new_staff_transaction_path), class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  </div>
</div>
