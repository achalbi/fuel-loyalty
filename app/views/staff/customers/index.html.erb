<% content_for :title, "Customer Search" %>

<div class="d-flex justify-content-between align-items-center mb-4 page-header">
  <div class="page-intro mb-0">
    <h1>Customer Search</h1>
    <p>Search by customer name or phone number to open the customer profile and manage vehicles quickly.</p>
  </div>
  <div class="page-actions">
    <%= link_to "Add Customer", new_staff_customer_path, class: "btn btn-primary" %>
  </div>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: staff_customers_path, method: :get, class: "row g-3 align-items-end", local: true do |form| %>
      <div class="col-lg-8">
        <%= form.label :q, "Search", class: "form-label" %>
        <%= form.text_field :q, value: @query, class: "form-control", placeholder: "Enter customer name or 10 digit phone number" %>
      </div>

      <div class="col-lg-4 d-flex gap-2 stack-mobile">
        <%= form.submit "Search", class: "btn btn-primary" %>
        <% if @query.present? %>
          <%= link_to "Clear", staff_customers_path, class: "btn btn-outline-secondary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<div class="card table-responsive">
  <div class="table-responsive">
    <table class="table responsive-table mb-0 table-hover align-middle">
      <thead class="table-light border-light">
        <tr>
          <th>Name</th>
          <th>Phone</th>
          <th>Status</th>
          <th>Vehicles</th>
          <th>Points</th>
          <th class="text-end">Action</th>
        </tr>
      </thead>
      <tbody>
        <% if @customers.any? %>
          <% @customers.each do |customer| %>
            <tr>
              <td data-label="Name"><%= customer.display_name %></td>
              <td data-label="Phone"><%= customer.phone_number %></td>
              <td data-label="Status">
                <span class="badge rounded-pill <%= customer.active? ? "text-bg-success" : "text-bg-secondary" %>">
                  <%= customer.status_label %>
                </span>
              </td>
              <td data-label="Vehicles"><%= customer.vehicles.map(&:vehicle_number).presence&.join(", ") || "N/A" %></td>
              <td data-label="Points"><%= customer.total_points %></td>
              <td data-label="Action" class="text-end">
                <div class="table-action-group justify-content-end">
                  <%= link_to "Open", customer_path(customer), class: "btn btn-sm btn-outline-primary" %>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="6" class="text-center text-muted py-4">
              <%= @query.present? ? "No customers matched that search." : "No customers available yet." %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
