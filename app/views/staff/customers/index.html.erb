<% content_for :title, "Customers" %>

<div class="mb-4 page-header admin-customers-header">
  <div class="page-intro mb-0">
    <h1>Customers</h1>
    <p>Search by customer name or phone number to open the customer profile and manage vehicles quickly.</p>
  </div>
  <div class="page-actions">
    <%= button_tag "+",
      type: "button",
      class: "customer-details-quick-action admin-customers-create-action",
      data: { bs_toggle: "modal", bs_target: "#addCustomerModal" },
      aria: { label: "Add Customer" },
      title: "Add Customer" %>
  </div>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <%= form_with url: staff_customers_path, method: :get, class: "row g-3 align-items-end", local: true do |form| %>
      <div class="col-lg-8">
        <%= form.label :q, "Search", class: "form-label" %>
        <%= form.text_field :q, value: @query, class: "form-control", placeholder: "Enter customer name or 10 digit phone number" %>
      </div>

      <div class="col-lg-4 d-flex gap-2 stack-mobile">
        <%= form.submit "Search", class: "btn btn-primary" %>
        <% if @query.present? %>
          <%= link_to "Clear", staff_customers_path, class: "btn btn-outline-secondary" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<div class="card shadow-sm admin-customers-card">
  <div class="card-body">
    <% if @customers.any? %>
      <div class="customer-details-vehicle-list admin-customers-list">
        <% @customers.each do |customer| %>
          <% display_name = customer.display_name.to_s.titleize %>
          <% vehicle_summary = customer.vehicles.map(&:vehicle_number).presence&.join(", ") || "No vehicles on file" %>
          <div class="customer-details-vehicle-row admin-customer-item">
            <div class="customer-details-vehicle-row__main admin-customer-item__main">
              <div class="admin-customer-item__heading">
                <span class="admin-customer-item__name"><%= display_name %></span>
                <span class="admin-customer-item__status <%= customer.active? ? "is-active" : "is-inactive" %>"><%= customer.status_label %></span>
              </div>
              <div class="admin-customer-item__details">
                <span class="admin-customer-item__phone">+91 <%= customer.phone_number %></span>
                <span class="admin-customer-item__vehicles"><%= vehicle_summary %></span>
              </div>
            </div>
            <div class="admin-customer-item__side">
              <span class="admin-customer-item__points"><%= customer.total_points %> pts</span>
              <%= link_to customer_path(customer),
                class: "customer-details-history-preview-action admin-customer-item__view",
                aria: { label: "View #{display_name}" },
                title: "View customer" do %>
                <i class="ti ti-eye" aria-hidden="true"></i>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="admin-customers-empty mb-0">
        <%= @query.present? ? "No customers matched that search." : "No customers available yet." %>
      </p>
    <% end %>
  </div>
</div>

<div
  class="modal fade customer-details-modal admin-customers-modal"
  id="addCustomerModal"
  tabindex="-1"
  aria-labelledby="addCustomerModalLabel"
  aria-hidden="true"
  data-auto-open-modal="<%= @customer.errors.any? %>">
  <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content confirm-modal-content customer-details-modal__content admin-customers-modal__content">
      <div class="modal-header border-0 pb-0">
        <div>
          <h2 class="modal-title h5 mb-1" id="addCustomerModalLabel">Add Customer</h2>
          <p class="text-muted mb-0 small">Create a new customer and optionally add the first vehicle right away.</p>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-3">
        <%= render "customers/form",
          customer: @customer,
          form_url: staff_customers_path,
          form_method: :post,
          include_vehicle_fields: true,
          submit_label: "Save Customer",
          title: "Add Customer",
          context: "modal" %>
      </div>
    </div>
  </div>
</div>
