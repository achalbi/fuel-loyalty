<% content_for :title, "Redeem Points" %>

<div class="row g-4" data-redemption-lookup-root data-lookup-url="<%= lookup_staff_customers_path %>">
  <div class="col-lg-7">
    <div class="card shadow-sm">
      <div class="card-body">
        <h1 class="h3 mb-3">Redeem Loyalty Points</h1>
        <p class="text-muted">Enter the customer's phone number, confirm the available balance, and record the redemption.</p>

        <% if @errors.present? %>
          <div class="alert alert-danger"><%= @errors.to_sentence %></div>
        <% end %>

        <%= form_with scope: :redemption, url: staff_redemptions_path, class: "vstack gap-3" do |form| %>
          <div>
            <%= form.label :phone_number, class: "form-label" %>
            <div class="input-group">
              <span class="input-group-text phone-prefix">+91</span>
              <%= form.telephone_field :phone_number, value: @prefill_phone_number, class: "form-control", required: true, placeholder: "10 digit phone number", inputmode: "numeric", autocomplete: "off", maxlength: 10, pattern: "\\d{10}", title: "Enter a 10 digit phone number", data: { phone_input: true, phone_number_field: true } %>
            </div>
          </div>

          <div>
            <%= form.label :points, "Points to Redeem", class: "form-label" %>
            <%= form.select :points,
              options_for_select(@prefill_points.present? ? [[@prefill_points.to_i, @prefill_points.to_i]] : [], @prefill_points),
              { prompt: "Select redeemable points" },
              class: "form-select",
              required: true,
              disabled: true,
              data: { points_select: true, prefill_value: @prefill_points } %>
            <div class="form-text">Points can only be redeemed in multiples of <%= PointsRedeemer::REDEMPTION_INCREMENT %>.</div>
          </div>

          <%= form.submit "Redeem Points", class: "btn btn-primary", disabled: true, data: { submit_button: true } %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card shadow-sm h-100 loyalty-result-card redemption-customer-shell">
      <div class="card-body">
        <div class="redemption-customer-shell__header">
          <div>
            <h2 class="h5 mb-1">Customer Details</h2>
            <p class="text-muted mb-0">Review the current balance before confirming the redemption.</p>
          </div>
        </div>

        <div class="redemption-customer-card redemption-customer-card--placeholder" data-customer-placeholder>
          <div class="redemption-customer-card__placeholder-icon" aria-hidden="true">
            <i class="ti ti-search"></i>
          </div>
          <p class="text-muted mb-0">Search by phone number to view the customer and current points balance.</p>
        </div>

        <div class="d-none redemption-customer-card" data-customer-panel>
          <div class="redemption-customer-card__hero">
            <span class="small-muted redemption-customer-card__eyebrow">Available Points</span>
            <strong class="redemption-customer-card__value" data-customer-points></strong>
            <span class="redemption-customer-card__note is-pending" data-customer-redeem-note></span>
          </div>

          <div class="redemption-customer-card__identity">
            <div class="redemption-customer-card__identity-heading">
              <h3 class="redemption-customer-card__name mb-0" data-customer-name></h3>
              <span class="redemption-customer-card__status" data-customer-status></span>
            </div>
            <p class="redemption-customer-card__phone mb-0" data-customer-phone></p>
          </div>

          <div class="redemption-customer-card__stats">
            <div class="redemption-customer-card__stat">
              <span class="redemption-customer-card__stat-label">Max Redeemable</span>
              <strong class="redemption-customer-card__stat-value" data-customer-max-redeemable></strong>
            </div>
            <div class="redemption-customer-card__stat">
              <span class="redemption-customer-card__stat-label">Vehicles on File</span>
              <strong class="redemption-customer-card__stat-value" data-customer-vehicles-count></strong>
            </div>
          </div>
        </div>

        <div class="alert alert-warning d-none mt-3 mb-0" data-customer-error role="alert"></div>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const initRedemptionLookup = () => {
      const root = document.querySelector("[data-redemption-lookup-root]");
      if (!root || root.dataset.lookupBound === "true") return;

      root.dataset.lookupBound = "true";

      const lookupUrl = root.dataset.lookupUrl;
      const phoneInput = root.querySelector("[data-phone-input]");
      const pointsSelect = root.querySelector("[data-points-select]");
      const submitButton = root.querySelector("[data-submit-button]");
      const placeholder = root.querySelector("[data-customer-placeholder]");
      const panel = root.querySelector("[data-customer-panel]");
      const errorBox = root.querySelector("[data-customer-error]");
      const nameTarget = root.querySelector("[data-customer-name]");
      const phoneTarget = root.querySelector("[data-customer-phone]");
      const pointsTarget = root.querySelector("[data-customer-points]");
      const statusTarget = root.querySelector("[data-customer-status]");
      const redeemNoteTarget = root.querySelector("[data-customer-redeem-note]");
      const maxRedeemableTarget = root.querySelector("[data-customer-max-redeemable]");
      const vehiclesCountTarget = root.querySelector("[data-customer-vehicles-count]");
      let availablePoints = 0;
      let maxRedeemablePoints = 0;
      let customerLoaded = false;
      let activeLookup = 0;
      const numberFormatter = new Intl.NumberFormat("en-IN");

      const populateRedeemableOptions = (maxPoints, selectedValue = "") => {
        const normalizedSelectedValue = String(selectedValue || "").trim();
        const placeholderLabel = maxPoints >= 100 ? "Select redeemable points" : "No redeemable points available";

        pointsSelect.innerHTML = "";

        const placeholderOption = document.createElement("option");
        placeholderOption.value = "";
        placeholderOption.textContent = placeholderLabel;
        pointsSelect.appendChild(placeholderOption);

        for (let points = 100; points <= maxPoints; points += 100) {
          const option = document.createElement("option");
          option.value = String(points);
          option.textContent = String(points);
          pointsSelect.appendChild(option);
        }

        if (normalizedSelectedValue !== "" && Number(normalizedSelectedValue) <= maxPoints && Number(normalizedSelectedValue) % 100 === 0) {
          pointsSelect.value = normalizedSelectedValue;
        } else {
          pointsSelect.value = "";
        }

        pointsSelect.disabled = !customerLoaded || maxPoints < 100;
      };

      const updateSubmitState = () => {
        const requestedPoints = Number(pointsSelect.value || 0);
        submitButton.disabled = !customerLoaded || pointsSelect.disabled || requestedPoints <= 0 || requestedPoints > maxRedeemablePoints;
      };

      const showError = (message, { keepPanel = false } = {}) => {
        errorBox.textContent = message;
        errorBox.classList.remove("d-none");
        placeholder.classList.add("d-none");
        panel.classList.toggle("d-none", !keepPanel);
        customerLoaded = false;
        availablePoints = 0;
        updateSubmitState();
      };

      const clearError = () => {
        errorBox.textContent = "";
        errorBox.classList.add("d-none");
      };

      const clearState = () => {
        clearError();
        placeholder.classList.remove("d-none");
        panel.classList.add("d-none");
        nameTarget.textContent = "";
        phoneTarget.textContent = "";
        pointsTarget.textContent = "";
        statusTarget.textContent = "";
        statusTarget.className = "redemption-customer-card__status";
        redeemNoteTarget.textContent = "";
        redeemNoteTarget.className = "redemption-customer-card__note is-pending";
        maxRedeemableTarget.textContent = "";
        vehiclesCountTarget.textContent = "";
        customerLoaded = false;
        availablePoints = 0;
        maxRedeemablePoints = 0;
        populateRedeemableOptions(0);
        updateSubmitState();
      };

      const loadCustomer = async () => {
        const phoneNumber = phoneInput.value.replace(/\D/g, "");

        if (phoneNumber.length !== 10) {
          clearState();
          return;
        }

        const lookupId = ++activeLookup;

        try {
          const response = await fetch(`${lookupUrl}?phone_number=${encodeURIComponent(phoneNumber)}`, {
            headers: { Accept: "application/json" }
          });

          const payload = await response.json();
          if (lookupId !== activeLookup) return;

          if (!response.ok || !payload.found) {
            showError(payload.message || "Customer not found for that phone number.");
            return;
          }

          clearError();
          placeholder.classList.add("d-none");
          panel.classList.remove("d-none");
          nameTarget.textContent = payload.customer.name;
          phoneTarget.textContent = payload.customer.phone_number;
          pointsTarget.textContent = numberFormatter.format(payload.customer.total_points || 0);
          statusTarget.textContent = payload.customer.status_label;
          statusTarget.className = `redemption-customer-card__status ${payload.customer.active ? "is-active" : "is-inactive"}`;
          maxRedeemableTarget.textContent = `${numberFormatter.format(payload.customer.max_redeemable_points || 0)} pts`;
          vehiclesCountTarget.textContent = String(payload.customer.vehicles.length);
          availablePoints = Number(payload.customer.total_points || 0);
          maxRedeemablePoints = Number(payload.customer.max_redeemable_points || 0);
          customerLoaded = true;
          populateRedeemableOptions(maxRedeemablePoints, pointsSelect.dataset.prefillValue || pointsSelect.value);
          pointsSelect.dataset.prefillValue = "";

          if (maxRedeemablePoints >= 100) {
            redeemNoteTarget.textContent = `Ready to redeem up to ${numberFormatter.format(maxRedeemablePoints)} points`;
            redeemNoteTarget.className = "redemption-customer-card__note is-redeemable";
          } else {
            const pointsNeeded = Math.max(100 - availablePoints, 0);
            redeemNoteTarget.textContent = `${numberFormatter.format(pointsNeeded)} more points needed to unlock rewards`;
            redeemNoteTarget.className = "redemption-customer-card__note is-pending";
          }

          if (maxRedeemablePoints < 100) {
            showError("This customer does not have enough redeemable points. Minimum redemption is 100 points.", { keepPanel: true });
            return;
          }

          updateSubmitState();
        } catch (_error) {
          if (lookupId !== activeLookup) return;
          showError("Unable to fetch customer details right now.");
        }
      };

      let lookupTimer;

      phoneInput.addEventListener("input", () => {
        clearTimeout(lookupTimer);
        lookupTimer = setTimeout(loadCustomer, 300);
      });

      phoneInput.addEventListener("blur", loadCustomer);
      pointsSelect.addEventListener("change", updateSubmitState);

      if (phoneInput.value.trim() !== "") {
        loadCustomer();
      } else {
        clearState();
      }
    };

    document.addEventListener("turbo:load", initRedemptionLookup);
    document.addEventListener("DOMContentLoaded", initRedemptionLookup);
  })();
</script>
