<!DOCTYPE html>
<html>
  <head>
    <% theme_setting = ThemeSetting.current %>
    <% cache_buster = pwa_cache_buster %>
    <title><%= content_for(:title) || "Ace Fuel Loyalty" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Ace Fuel Loyalty">
    <meta name="application-name" content="Ace Fuel Loyalty">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="<%= theme_setting.primary_color %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png?v=<%= cache_buster %>" type="image/png">
    <link rel="icon" href="/icon.svg?v=<%= cache_buster %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon-192.png?v=<%= cache_buster %>">
    <link rel="manifest" href="<%= pwa_manifest_path(v: cache_buster) %>">
    <% if firebase_browser_sdk_enabled? %>
      <script>
        window.fuelLoyaltyPushSettings = <%= raw(json_escape(firebase_web_push_settings.to_json)) %>;
        window.__fuelLoyaltyFirebaseReady = window.__fuelLoyaltyFirebaseReady || new Promise((resolve) => {
          window.__resolveFuelLoyaltyFirebaseReady = resolve;
        });
      </script>
    <% end %>
    <%= javascript_include_tag "theme_boot", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "bootstrap.min", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tabler-icons.min", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= dynamic_theme_style_tag(theme_setting) %>
    <%= javascript_include_tag "bootstrap.bundle.min", "data-turbo-track": "reload", defer: true %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>

  <body class="<%= user_signed_in? ? "app-shell-body" : "public-shell-body" %>">
    <% flash_messages = flash.to_hash.except("transaction_summary") %>
    <% if user_signed_in? %>
      <div id="overlay" class="overlay"></div>

      <nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">
        <button id="mobileBtn" class="btn btn-light btn-icon btn-sm d-lg-none me-2">
          <i class="ti ti-layout-sidebar-left-expand"></i>
        </button>

        <div class="ms-auto d-flex align-items-center gap-2">
          <% if current_user.staff? || current_user.admin? %>
            <%= link_to new_staff_transaction_path,
              class: "btn btn-light btn-icon btn-sm",
              aria: { label: "New Transaction" },
              title: "New Transaction" do %>
              <i class="ti ti-gas-station" aria-hidden="true"></i>
            <% end %>
          <% end %>

          <span class="badge rounded-pill text-bg-light border px-3 py-2 topbar-role-badge"><%= current_user.role.titleize %></span>

          <div class="dropdown">
            <a href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" class="avatar avatar-sm rounded-circle bg-primary-subtle text-primary text-decoration-none">
              <span class="avatar-initials"><%= current_user.avatar_initial %></span>
            </a>

            <div class="dropdown-menu dropdown-menu-end p-0 user-menu">
              <div class="d-flex gap-3 align-items-center border-bottom px-3 py-3">
                <div class="avatar avatar-md rounded-circle bg-primary-subtle text-primary">
                  <span class="avatar-initials"><%= current_user.avatar_initial %></span>
                </div>
                <div>
                  <h4 class="mb-0 small fw-semibold"><%= current_user.display_name %></h4>
                  <p class="mb-0 small text-muted"><%= current_user.display_phone_number || "Mobile not set" %></p>
                </div>
              </div>
              <div class="border-bottom px-3 py-2 d-lg-none d-flex flex-column align-items-center gap-2">
                <div class="theme-switch-inline d-flex justify-content-center">
                  <div class="theme-switch-shell theme-switch-shell--compact" aria-label="Theme switch">
                    <i class="ti ti-sun-high theme-switch-icon"></i>
                    <div class="form-check form-switch mb-0">
                      <input class="form-check-input theme-switch-input" type="checkbox" role="switch" data-theme-switch aria-label="Toggle light and dark mode">
                    </div>
                    <i class="ti ti-moon-stars theme-switch-icon"></i>
                    <span class="theme-switch-text" data-theme-label></span>
                  </div>
                </div>
                <div class="dropdown-divider my-0 w-100"></div>
                <div class="sidebar-mode-inline d-flex justify-content-center">
                  <div class="sidebar-mode-shell" aria-label="Sidebar display mode">
                    <i class="ti ti-layout-sidebar-left-collapse sidebar-mode-icon" aria-hidden="true"></i>
                    <div class="form-check form-switch mb-0">
                      <input
                        class="form-check-input sidebar-mode-input"
                        type="checkbox"
                        role="switch"
                        data-sidebar-mode-switch
                        aria-label="Show side navbar as icon-only bar">
                    </div>
                    <i class="ti ti-layout-sidebar-left-expand sidebar-mode-icon" aria-hidden="true"></i>
                    <span class="sidebar-mode-text">Icons</span>
                  </div>
                </div>
              </div>
              <div class="p-2 d-flex flex-column gap-1 small">
                <%= link_to "Change Password", edit_password_path, class: "dropdown-item rounded-2" %>
                <%= button_to "Logout", destroy_user_session_path, method: :delete, form_class: "m-0", class: "dropdown-item rounded-2 text-danger bg-transparent border-0 text-start w-100" %>
              </div>
            </div>
          </div>
        </div>
      </nav>

      <aside id="sidebar" class="sidebar">
        <div class="logo-area">
          <%= link_to root_path, class: "brand-lockup" do %>
            <span class="brand-mark" aria-hidden="true"><%= image_tag "/icon.svg?v=#{cache_buster}", alt: "", class: "brand-mark-image" %></span>
            <span class="logo-text">Ace Fuel Loyalty</span>
          <% end %>
        </div>

        <ul class="nav flex-column">
          <% if current_user.admin? %>
            <li class="px-4 py-2"><small class="nav-section-label">Admin</small></li>
            <li><%= link_to admin_dashboard_path, class: "nav-link #{'active' if current_page?(admin_dashboard_path)}" do %><i class="ti ti-home"></i><span class="nav-text">Dashboard</span><% end %></li>
            <li><%= link_to admin_users_path, class: "nav-link #{'active' if request.path.start_with?(admin_users_path)}" do %><i class="ti ti-user-cog"></i><span class="nav-text">Users</span><% end %></li>
            <li><%= link_to admin_customers_path, class: "nav-link #{'active' if current_page?(admin_customers_path)}" do %><i class="ti ti-users"></i><span class="nav-text">Customers</span><% end %></li>
            <li><%= link_to admin_transactions_path, class: "nav-link #{'active' if current_page?(admin_transactions_path)}" do %><i class="ti ti-receipt"></i><span class="nav-text">Transactions</span><% end %></li>
            <li><%= link_to admin_fuel_types_path, class: "nav-link #{'active' if controller_path == 'admin/fuel_types'}" do %><i class="ti ti-gas-station"></i><span class="nav-text">Fuel Types</span><% end %></li>
            <li><%= link_to admin_vehicle_types_path, class: "nav-link #{'active' if controller_path == 'admin/vehicle_types'}" do %><i class="ti ti-car"></i><span class="nav-text">Vehicle Types</span><% end %></li>
            <li><%= link_to admin_fuel_reward_rates_path, class: "nav-link #{'active' if current_page?(admin_fuel_reward_rates_path)}" do %><i class="ti ti-adjustments"></i><span class="nav-text">Reward Rates</span><% end %></li>
            <li><%= link_to new_staff_redemption_path, class: "nav-link #{'active' if current_page?(new_staff_redemption_path)}" do %><i class="ti ti-gift-card"></i><span class="nav-text">Redeem Points</span><% end %></li>
            <li><%= link_to new_admin_points_adjustment_path, class: "nav-link #{'active' if current_page?(new_admin_points_adjustment_path)}" do %><i class="ti ti-arrows-diff"></i><span class="nav-text">Adjust Points</span><% end %></li>
            <li class="px-4 pt-4 pb-2"><small class="nav-section-label">Attendance</small></li>
            <li><%= link_to admin_staff_members_path, class: "nav-link #{'active' if controller_path.in?(%w[admin/staff_members admin/shift_assignments])}" do %><i class="ti ti-users-group"></i><span class="nav-text">Staff</span><% end %></li>
            <li><%= link_to admin_shift_templates_path, class: "nav-link #{'active' if controller_path == 'admin/shift_templates'}" do %><i class="ti ti-clock-hour-4"></i><span class="nav-text">Shifts</span><% end %></li>
            <li><%= link_to admin_shift_cycles_path, class: "nav-link #{'active' if controller_path == 'admin/shift_cycles'}" do %><i class="ti ti-repeat"></i><span class="nav-text">Cycles</span><% end %></li>
            <li><%= link_to admin_attendance_runs_path, class: "nav-link #{'active' if controller_path == 'admin/attendance_runs'}" do %><i class="ti ti-calendar-check"></i><span class="nav-text">Attendance</span><% end %></li>
            <li class="px-4 pt-4 pb-2"><small class="nav-section-label">App Management</small></li>
            <li><%= link_to admin_notifications_path, class: "nav-link #{'active' if current_page?(admin_notifications_path)}" do %><i class="ti ti-bell-ringing"></i><span class="nav-text">Notifications</span><% end %></li>
            <li><%= link_to admin_theme_settings_path, class: "nav-link #{'active' if current_page?(admin_theme_settings_path)}" do %><i class="ti ti-palette"></i><span class="nav-text">Theme</span><% end %></li>
          <% else %>
            <li class="px-4 py-2"><small class="nav-section-label">Operations</small></li>
            <li><%= link_to new_staff_transaction_path, class: "nav-link #{'active' if current_page?(new_staff_transaction_path)}" do %><i class="ti ti-gas-station"></i><span class="nav-text">New Transaction</span><% end %></li>
            <li><%= link_to staff_customers_path, class: "nav-link #{'active' if current_page?(staff_customers_path)}" do %><i class="ti ti-users"></i><span class="nav-text">Customers</span><% end %></li>
            <li><%= link_to new_staff_redemption_path, class: "nav-link #{'active' if current_page?(new_staff_redemption_path)}" do %><i class="ti ti-gift-card"></i><span class="nav-text">Redeem Points</span><% end %></li>
            <li><%= link_to staff_notifications_path, class: "nav-link #{'active' if current_page?(staff_notifications_path)}" do %><i class="ti ti-bell-ringing"></i><span class="nav-text">Notifications</span><% end %></li>
          <% end %>

          <li class="px-4 pt-4 pb-2"><small class="nav-section-label">Access</small></li>
          <li><%= link_to new_loyalty_path, class: "nav-link #{'active' if current_page?(new_loyalty_path)}" do %><i class="ti ti-search"></i><span class="nav-text">Loyalty Lookup</span><% end %></li>
        </ul>
      </aside>

      <main id="content" class="content py-10">
        <div class="container-fluid <%= flash_messages.any? ? 'pt-0 pb-3 has-flash' : 'py-3' %>">
          <% flash_messages.each do |type, message| %>
            <% bootstrap_type = type.to_s == "notice" ? "success" : "danger" %>
            <div class="alert alert-<%= bootstrap_type %> border-0 shadow-sm"><%= message %></div>
          <% end %>

          <%= yield %>
        </div>
      </main>
    <% else %>
      <% unless devise_controller? %>
        <nav class="navbar bg-white border-bottom px-3 py-3">
          <div class="container">
            <%= link_to root_path, class: "brand-lockup" do %>
              <span class="brand-mark" aria-hidden="true"><%= image_tag "/icon.svg?v=#{cache_buster}", alt: "", class: "brand-mark-image" %></span>
              <span class="logo-text">Ace Fuel Loyalty</span>
            <% end %>

            <div class="d-flex align-items-center gap-2">
              <!-- <%= link_to "Loyalty Lookup", new_loyalty_path, class: "btn btn-light border" %> -->
              <%= link_to "Staff Login", new_user_session_path, class: "btn btn-primary" %>
            </div>
          </div>
        </nav>
      <% end %>

      <main class="<%= devise_controller? ? '' : 'public-main py-3' %>">
        <div class="container">
          <% flash_messages.each do |type, message| %>
            <% bootstrap_type = type.to_s == "notice" ? "success" : "danger" %>
            <div class="alert alert-<%= bootstrap_type %> border-0 shadow-sm"><%= message %></div>
          <% end %>

          <%= yield %>
        </div>
      </main>
    <% end %>

    <div class="theme-switch-floating">
      <div class="theme-switch-shell" aria-label="Theme switch">
        <i class="ti ti-sun-high theme-switch-icon"></i>
        <div class="form-check form-switch mb-0">
          <input class="form-check-input theme-switch-input" type="checkbox" role="switch" data-theme-switch aria-label="Toggle light and dark mode">
        </div>
        <i class="ti ti-moon-stars theme-switch-icon"></i>
        <span class="theme-switch-text" data-theme-label></span>
      </div>
    </div>

    <div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-labelledby="confirmDeleteModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content confirm-modal-content">
          <div class="modal-header border-0 pb-0">
            <h2 class="modal-title h5 mb-0" id="confirmDeleteModalLabel">Confirm deletion</h2>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body pt-3">
            <p class="mb-0 text-muted" data-confirm-modal-message>Are you sure you want to delete this item?</p>
          </div>
          <div class="modal-footer border-0 pt-0">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-danger" data-confirm-modal-submit>Delete</button>
          </div>
        </div>
      </div>
    </div>

    <% if firebase_browser_sdk_enabled? %>
      <%= render "shared/firebase_sdk" %>
    <% end %>
  </body>
</html>
